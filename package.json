{
  "name": "health-sync-cicd",
  "version": "1.0.0",
  "description": "CI/CD pipeline for health sync system",
  "scripts": {
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:validation": "node scripts/validate_sync.js",
    "lint": "eslint scripts/",
    "deploy:staging": "node scripts/deploy.js --env=staging",
    "deploy:production": "node scripts/deploy.js --env=production",
    "validate:staging": "node scripts/validate_environment.js --env=staging",
    "validate:production": "node scripts/validate_environment.js --env=production",
    "dry-run": "node scripts/health-sync/unified_sync.js --dry-run",
    "backup": "node scripts/backup_data.js"
  },
  "devDependencies": {
    "eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
